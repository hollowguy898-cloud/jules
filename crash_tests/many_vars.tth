// CRASH TEST: Many variables in one function
fn many_vars() i32 {
    var a0: i32 = 0;
    var a1: i32 = 1;
    var a2: i32 = 2;
    var a3: i32 = 3;
    var a4: i32 = 4;
    var a5: i32 = 5;
    var a6: i32 = 6;
    var a7: i32 = 7;
    var a8: i32 = 8;
    var a9: i32 = 9;
    var a10: i32 = 10;
    var a11: i32 = 11;
    var a12: i32 = 12;
    var a13: i32 = 13;
    var a14: i32 = 14;
    var a15: i32 = 15;
    var a16: i32 = 16;
    var a17: i32 = 17;
    var a18: i32 = 18;
    var a19: i32 = 19;
    return a0 + a1 + a2 + a3 + a4 + a5 + a6 + a7 + a8 + a9 + a10 + a11 + a12 + a13 + a14 + a15 + a16 + a17 + a18 + a19;
}
fn main() i32 {
    return many_vars();
}
