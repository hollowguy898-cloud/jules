// CRASH TEST: Deep nesting of if/else
fn deep_nest() i32 {
    val x: i32 = 1;
    if (x == 1) {
        if (x == 1) {
            if (x == 1) {
                if (x == 1) {
                    if (x == 1) {
                        if (x == 1) {
                            if (x == 1) {
                                if (x == 1) {
                                    return 1;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    return 0;
}
fn main() i32 {
    return deep_nest();
}
