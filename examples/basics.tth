// Basic variable declarations and arithmetic
fn add(x: i32, y: i32) i32 pure {
    return x + y;
}

fn multiply(x: i32, y: i32) i32 pure {
    return x * y;
}

fn main() i32 {
    val a: i32 = 10;
    val b: i32 = 20;
    val sum = add(a, b);
    val product = multiply(a, b);
    var counter: i32 = 0;
    counter = sum - 5;
    if (counter > 20) {
        counter = counter - 1;
    } else {
        counter = counter + 1;
    }
    return counter;
}
